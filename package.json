{
  "name": "costkey",
  "version": "0.2.3",
  "description": "AI cost observability. Track every LLM call's cost, tokens, and latency with one line of code.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "ai",
    "llm",
    "cost",
    "tracking",
    "observability",
    "openai",
    "anthropic",
    "gemini",
    "google",
    "azure",
    "tokens",
    "monitoring",
    "observability",
    "tracing"
  ],
  "author": "CostKey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/costkey/costkey"
  },
  "homepage": "https://costkey.dev",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
